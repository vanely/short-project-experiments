const { calculateDiscount } = require('./discount');

// Helper function to check if discount amounts match expected values
function checkDiscountAmounts(actual, expected, tolerance = 0.01) {
  if (Math.abs(actual - expected) > tolerance) {
    return false;
  }
  return true;
}

